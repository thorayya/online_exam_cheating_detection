import mediapipe as mp
from mediapipe.tasks import python
from mediapipe.tasks.python import vision
import cv2
import numpy as np
import time
from google.colab import files

cap = cv2.VideoCapture(0)
BaseOptions = mp.tasks.BaseOptions
FaceLandmarker = mp.tasks.vision.FaceLandmarker
FaceLandmarkerOptions = mp.tasks.vision.FaceLandmarkerOptions
VisionRunningMode = mp.tasks.vision.RunningMode.VIDEO


model_path = 'face_landmarker_v2_with_blendshapes.task'

options = FaceLandmarkerOptions(
    base_options=BaseOptions(model_asset_path=model_path),
    running_mode=VisionRunningMode)

detector = vision.FaceLandmarker.create_from_options(options)


NOSE = 1
CHIN = 152
LEFT_EYE = 33
RIGHT_EYE = 263
MOUTH_LEFT = 61
MOUTH_RIGHT = 291

fps = cap.get(cv2.CAP_PROP_FPS)
frame_id = 0

model_points = np.array([
    [0, 0, 0],
    [0, -330, -65],
    [-225, 170, -135],
    [225, 170, -135],
    [-150, -150, -125],
    [150, -150, -125]
], dtype=np.float64)

dist_coeffs = np.zeros((5,1))


def focalLength(focalLenght, h, w):

  camera_matrix = np.array([
      [focalLenght, 0, w/2],
      [0, focalLenght, h/2],
      [0, 0, 1]
  ])

  return camera_matrix


while cap.isOpened():

  ret, frame = cap.read()

  if not ret:
    print("failed to grab image")
    break



  h, w, _ = frame.shape
  frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

  mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=frame)

  timestamp_ms = int((frame_id / fps) * 1000)
  detection_result = detector.detect_for_video(mp_image, timestamp_ms)


  camera_matrix = focalLength(1000, h, w)


  if detection_result.face_landmarks:

    landmark = detection_result.face_landmarks[0]

    nose = landmark[NOSE]
    chin = landmark[CHIN]
    left_eye = landmark[LEFT_EYE]
    right_eye = landmark[RIGHT_EYE]
    mouth_left = landmark[MOUTH_LEFT]
    mouth_right = landmark[MOUTH_RIGHT]


    image_points = np.array([
                            [nose.x*w, nose.y*h],
                            [chin.x*w, chin.y*h],
                            [left_eye.x*w, left_eye.y*h],
                            [right_eye.x*w, right_eye.y*h],
                            [mouth_left.x*w, mouth_left.y*h],
                            [mouth_right.x*w, mouth_right.y*h]
                            ],
                            dtype = np.float64)


    success, rvec, tvec = cv2.solvePnP(
    model_points,
    image_points,
    camera_matrix,
    dist_coeffs
    )

    rotation_matrix, _ = cv2.Rodrigues(rvec)
    # pose_matrix = cv2.hconcat((rotation_matrix, tvec))
    # i should gain the width and height of camera


  if cv2.waitKey(1) & 0xFF == ord('q'):
    break


  frame_id += 1

cap.release()
cv2.destroyAllWindows()
